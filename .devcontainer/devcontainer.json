{
  "name": "Python + Terraform + Azure + Kubernetes",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "HashiCorp.terraform",
        "ms-azuretools.vscode-azurecli",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "GitHub.Copilot-Chat"
      ]
    }
  },
  "remoteEnv": {
    "SSH_KEY_NAME": "${localEnv:SSH_KEY_NAME:personal}"
  },
  "mounts": [
    "source=${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
  ],
  "postCreateCommand": "git config --local user.signingkey /home/vscode/.ssh/${SSH_KEY_NAME}.pub && git config --local gpg.format ssh && git config --local commit.gpgsign true && for d in services/*; do if [ -f \"$d/pyproject.toml\" ]; then (cd \"$d\" && poetry install); fi; done",
  "postStartCommand": "bash /workspaces/cmu-aegis-scholar/.devcontainer/shell-init.sh",
  "forwardPorts": [8000]
}
