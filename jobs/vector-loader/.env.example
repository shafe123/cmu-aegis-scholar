# Example .env file for data-loader service
# Copy this to .env and update values as needed

# Vector DB API settings
VECTOR_DB_URL=http://vector-db:8002
VECTOR_DB_TIMEOUT=300

# Data source settings
DATA_DIR=/data/dtic_compressed

# Collection settings
COLLECTION_NAME=aegis_vectors
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Processing settings
BATCH_SIZE=100
MAX_RECORDS=

# Loading behavior
SKIP_IF_LOADED=true
MIN_ENTITIES_THRESHOLD=100

# Logging
LOG_LEVEL=INFO
