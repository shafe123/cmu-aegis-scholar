import requests
import json
from datetime import datetime, timedelta

# ── Configuration ──────────────────────────────────────
OPENALEX_BASE_URL = "https://api.openalex.org"
EMAIL = "your-team@example.com"  # Gets you polite pool access
PER_PAGE = 50  # Max 200

# ── Step 1: Query OpenAlex for recent works ────────────
def fetch_recent_works(days_back=7):
    """Pull works published in the last N days."""
    since_date = (datetime.now() - timedelta(days=days_back)).strftime("%Y-%m-%d")

    all_works = []
    page = 1

    while True:
        response = requests.get(
            f"{OPENALEX_BASE_URL}/works",
            params={
                "filter": f"from_publication_date:{since_date}",
                "per_page": 200,          # Max it out — same credit cost per page
                "page": page,
                "api_key": "okUdYJ1spHzXFBLMPJuB6n",    # ← THIS IS THE CHANGE
            }
        )

        GET https://api.openalex.org/rate-limit?api_key=okUdYJ1spHzXFBLMPJuB6n

        response.raise_for_status()
        data = response.json()

        results = data.get("results", [])
        if not results:
            break  # No more pages

        all_works.extend(results)
        page += 1

        # Safety limit for testing — remove in production
        if page > 3:
            break

    return all_works


# ── Step 2: Save raw JSON (simulates writing to Blob Storage) ──
def save_to_file(works, filename="raw_openalex_data.json"):
    """In production, this becomes 'upload to Azure Blob Storage'."""
    with open(filename, "w") as f:
        json.dump(works, f, indent=2)
    print(f"Saved {len(works)} works to {filename}")


# ── Run it ─────────────────────────────────────────────
if __name__ == "__main__":
    print("Fetching recent works from OpenAlex...")
    works = fetch_recent_works(days_back=7)
    save_to_file(works)
    print(f"Done. Got {len(works)} works.")